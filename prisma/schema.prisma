// Multi-tenant inventory domain.
// Every domain table carries organizationId — tenant isolation is enforced
// in the data-access layer by always scoping queries to the session's org.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs live outside the schema in Prisma 7:
// runtime uses the pg adapter in src/lib/prisma.ts (DATABASE_URL, pooled),
// migrations use prisma.config.ts (DIRECT_URL, direct connection).
datasource db {
  provider = "postgresql"
}

// ---------- Tenancy & identity ----------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  categories     Category[]
  products       Product[]
  suppliers      Supplier[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  requisitions   Requisition[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  // Small profile photo stored as a data URL (client-side resized before
  // upload) — no external object storage is wired up for this project.
  avatarUrl    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships           Membership[]
  stockMovements        StockMovement[]
  purchaseOrders        PurchaseOrder[]
  requestedRequisitions Requisition[]   @relation("RequisitionRequester")
  decidedRequisitions   Requisition[]   @relation("RequisitionDecider")

  @@map("users")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("memberships")
}

// ---------- Catalog ----------

model Category {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@map("categories")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  categoryId     String?
  sku            String
  name           String
  description    String?
  // Client-resized (max 512px) JPEG stored as a base64 data URL — same
  // no-external-storage approach as User.avatarUrl, kept small on purpose.
  imageUrl       String?  @db.Text
  unit           String   @default("pcs")
  // Cached balance of the StockMovement ledger; updated in the same
  // transaction as each movement. Never mutated directly.
  quantity       Int      @default(0)
  minStock       Int      @default(0)
  price          Decimal  @default(0) @db.Decimal(12, 2)
  costPrice      Decimal  @default(0) @db.Decimal(12, 2)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  requisitionItems   RequisitionItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, isArchived])
  @@index([categoryId])
  @@map("products")
}

// ---------- Stock ledger ----------

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String
  productId      String
  createdById    String
  type           StockMovementType
  // Signed delta applied to Product.quantity (IN > 0, OUT < 0,
  // ADJUSTMENT either). Immutable: corrections are new ADJUSTMENT rows.
  delta          Int
  note           String?
  referenceId    String? // e.g. PurchaseOrder id that produced this movement
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([organizationId, productId, createdAt])
  @@index([organizationId, createdAt])
  @@map("stock_movements")
}

// ---------- Requisitions (เบิก/คืนสินค้า) ----------

enum RequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  RETURN_REQUESTED
  RETURNED
}

model Requisition {
  id             String            @id @default(cuid())
  organizationId String
  requesterId    String
  decidedById    String?
  reqNumber      String
  status         RequisitionStatus @default(PENDING)
  note           String?
  // Set when an admin approves/rejects; return flow reuses it for the
  // return confirmation timestamp via returnedAt below.
  decidedAt      DateTime?
  returnedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester    User              @relation("RequisitionRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  decidedBy    User?             @relation("RequisitionDecider", fields: [decidedById], references: [id], onDelete: Restrict)
  items        RequisitionItem[]

  @@unique([organizationId, reqNumber])
  @@index([organizationId, status])
  @@index([organizationId, requesterId, createdAt])
  @@map("requisitions")
}

model RequisitionItem {
  id            String @id @default(cuid())
  requisitionId String
  productId     String
  quantity      Int

  requisition Requisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([requisitionId, productId])
  @@map("requisition_items")
}

// ---------- Purchasing ----------

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, name])
  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String
  supplierId     String
  createdById    String
  orderNumber    String
  status         PurchaseOrderStatus @default(DRAFT)
  notes          String?
  orderedAt      DateTime?
  receivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy    User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items        PurchaseOrderItem[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([purchaseOrderId, productId])
  @@map("purchase_order_items")
}

// ---------- Deployment-wide settings ----------

// Singleton row (always id "global") for settings that apply to the whole
// deployment rather than one organization — e.g. the public sign-in page is
// shown before any organization is known, so a per-org flag can't gate it.
model SystemSetting {
  id                    String   @id @default("global")
  showLoginDemoAccounts Boolean  @default(true)
  updatedAt             DateTime @updatedAt

  @@map("system_settings")
}
